---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---
<aside class="mt-6 p-5 bg-amber-50 border border-amber-200 rounded-lg">
  <div class="flex items-center gap-2 text-[12px] font-semibold uppercase tracking-wider text-amber-700 mb-3">
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Kiedy ten kalkulator NIE jest właściwym narzędziem
  </div>
  <ul class="text-[13px] text-amber-900 space-y-1.5">
    {items.map((s) => (
      <li class="leading-relaxed">— {s}</li>
    ))}
  </ul>
</aside>
