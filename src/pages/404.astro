---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Nie znaleziono strony — 404" noindex={true}>
  <div class="text-center max-w-md mx-auto py-16">
    <div class="font-mono text-6xl font-bold text-ink-300 mb-4">404</div>
    <h1 class="text-2xl font-semibold text-ink-900 mb-3">Nie znaleziono</h1>
    <p class="text-ink-600 mb-6">Adres, który wpisałeś, nie istnieje na tej stronie.</p>
    <a href="/" class="inline-block px-5 py-2.5 bg-ink-900 text-white rounded-md hover:bg-ink-700 transition text-[14px]">
      Wróć na stronę główną
    </a>
  </div>
</Layout>
